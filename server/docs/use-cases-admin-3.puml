@startuml Admin Use Cases (3/3)

left to right direction

skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam defaultFontSize 13
skinparam usecaseFontSize 12
skinparam actorFontSize 15
skinparam backgroundColor white
skinparam nodesep 8
skinparam ranksep 25
skinparam padding 4
skinparam roundcorner 8
skinparam ArrowColor #555555
skinparam ArrowFontSize 10
skinparam rectangleBackgroundColor #EBF2FF
skinparam rectangleBorderColor #3A6BC8
skinparam rectangleFontSize 13
skinparam rectangleFontStyle bold
skinparam usecaseBackgroundColor #FFFFFF
skinparam usecaseBorderColor #3A6BC8
skinparam ActorBackgroundColor #FFFFFF
skinparam ActorBorderColor #1A2E50

actor Admin

rectangle "Task Report Moderation" {
  usecase "List Task Reports" as UC_REPORT_LIST
  usecase "View Task Report Details" as UC_REPORT_GET
  usecase "Correct Task Content" as UC_REPORT_CORRECT
  usecase "Dismiss Task Report" as UC_REPORT_DISMISS
}

Admin --> UC_REPORT_LIST
Admin --> UC_REPORT_GET
Admin --> UC_REPORT_CORRECT
Admin --> UC_REPORT_DISMISS

UC_REPORT_CORRECT ..> UC_REPORT_GET : <<include>>
UC_REPORT_DISMISS ..> UC_REPORT_GET : <<include>>

@enduml

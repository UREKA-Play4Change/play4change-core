@startuml Learner Use Cases (2/3)

left to right direction

skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam defaultFontSize 13
skinparam usecaseFontSize 12
skinparam actorFontSize 15
skinparam backgroundColor white
skinparam nodesep 8
skinparam ranksep 25
skinparam padding 4
skinparam roundcorner 8
skinparam ArrowColor #555555
skinparam ArrowFontSize 10
skinparam rectangleBackgroundColor #EBF2FF
skinparam rectangleBorderColor #3A6BC8
skinparam rectangleFontSize 13
skinparam rectangleFontStyle bold
skinparam usecaseBackgroundColor #FFFFFF
skinparam usecaseBorderColor #3A6BC8
skinparam ActorBackgroundColor #FFFFFF
skinparam ActorBorderColor #1A2E50

actor Learner

rectangle "Topic Browsing & Enrollment" {
  usecase "Browse Available Topics" as UC_TOPIC_LIST
  usecase "Enroll in Topic" as UC_TOPIC_ENROLL
  usecase "View Enrollment Status" as UC_TOPIC_ENROLLMENT
}

rectangle "Daily Learning" {
  usecase "Get Today's Task" as UC_TASK_TODAY
  usecase "Submit Task Answer" as UC_TASK_SUBMIT
  usecase "Submit Photo Task" as UC_TASK_PHOTO
  usecase "View Learning Roadmap" as UC_ROADMAP
}

Learner --> UC_TOPIC_LIST
Learner --> UC_TOPIC_ENROLL
Learner --> UC_TOPIC_ENROLLMENT

Learner --> UC_TASK_TODAY
Learner --> UC_TASK_SUBMIT
Learner --> UC_TASK_PHOTO
Learner --> UC_ROADMAP

UC_TOPIC_ENROLL ..> UC_TOPIC_LIST : <<include>>
UC_TASK_TODAY ..> UC_TOPIC_ENROLLMENT : <<include>>
UC_TASK_SUBMIT ..> UC_TASK_TODAY : <<include>>
UC_TASK_PHOTO ..> UC_TASK_TODAY : <<include>>

@enduml

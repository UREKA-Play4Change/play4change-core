@startuml Admin Use Cases

left to right direction

skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam defaultFontSize 13
skinparam usecaseFontSize 12
skinparam actorFontSize 15
skinparam backgroundColor white
skinparam nodesep 8
skinparam ranksep 25
skinparam padding 4
skinparam roundcorner 8
skinparam ArrowColor #555555
skinparam ArrowFontSize 10
skinparam rectangleBackgroundColor #EBF2FF
skinparam rectangleBorderColor #3A6BC8
skinparam rectangleFontSize 13
skinparam rectangleFontStyle bold
skinparam usecaseBackgroundColor #FFFFFF
skinparam usecaseBorderColor #3A6BC8
skinparam ActorBackgroundColor #FFFFFF
skinparam ActorBorderColor #1A2E50

actor Admin

rectangle "Authentication" {
  usecase "Request Magic Link" as UC_AUTH_ML
  usecase "Verify Magic Link" as UC_AUTH_VERIFY
  usecase "OAuth Login" as UC_AUTH_OAUTH
  usecase "Refresh Token" as UC_AUTH_REFRESH
  usecase "Logout" as UC_AUTH_LOGOUT
}

rectangle "Profile" {
  usecase "View Own Profile" as UC_PROF_GET
}

rectangle "Topic Management" {
  usecase "Create Topic from URL" as UC_TOPIC_URL
  usecase "Create Topic from PDF" as UC_TOPIC_PDF
  usecase "List Topics" as UC_TOPIC_LIST
  usecase "View Topic Details" as UC_TOPIC_GET
  usecase "Regenerate Topic Tasks" as UC_TOPIC_REGEN
}

rectangle "Analytics" {
  usecase "View Topic Badge Statistics" as UC_BADGE_STATS
}

rectangle "Task Report Moderation" {
  usecase "List Task Reports" as UC_REPORT_LIST
  usecase "View Task Report Details" as UC_REPORT_GET
  usecase "Correct Task Content" as UC_REPORT_CORRECT
  usecase "Dismiss Task Report" as UC_REPORT_DISMISS
}

Admin --> UC_AUTH_ML
Admin --> UC_AUTH_VERIFY
Admin --> UC_AUTH_OAUTH
Admin --> UC_AUTH_REFRESH
Admin --> UC_AUTH_LOGOUT

Admin --> UC_PROF_GET

Admin --> UC_TOPIC_URL
Admin --> UC_TOPIC_PDF
Admin --> UC_TOPIC_LIST
Admin --> UC_TOPIC_GET
Admin --> UC_TOPIC_REGEN

Admin --> UC_BADGE_STATS

Admin --> UC_REPORT_LIST
Admin --> UC_REPORT_GET
Admin --> UC_REPORT_CORRECT
Admin --> UC_REPORT_DISMISS

UC_TOPIC_URL ..> UC_TOPIC_LIST : <<extends>>
UC_TOPIC_PDF ..> UC_TOPIC_LIST : <<extends>>
UC_REPORT_CORRECT ..> UC_REPORT_GET : <<include>>
UC_REPORT_DISMISS ..> UC_REPORT_GET : <<include>>
UC_BADGE_STATS ..> UC_TOPIC_GET : <<include>>

@enduml

    {
      "id": 11,
      "title": "Adaptive Reuse Strategy Distribution",
      "type": "piechart",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },

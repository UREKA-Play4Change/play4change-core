@startuml architecture
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

LAYOUT_WITH_LEGEND()

title System Architecture — Container Diagram

' ────────────────────────────────
' CLIENTS
' ────────────────────────────────
System_Boundary(clients, "Client Layer") {
    Container(mobile_app, "Mobile App", "iOS / Android", "Native mobile client for end-users")
    Container(web_app, "Web App", "SPA / PWA", "Browser-based client for end-users")
}

' ────────────────────────────────
' GATEWAY
' ────────────────────────────────
Container(api_gateway, "API Gateway", "Reverse Proxy / Load Balancer", "Single entry point — handles routing, rate-limiting, TLS termination and auth token forwarding")

' ────────────────────────────────
' CORE SERVICES
' ────────────────────────────────
System_Boundary(backend, "Backend Services") {
    Container(identity_svc, "Identity Service", "REST / gRPC", "Handles user registration, login, token issuance and session management")
    Container(content_creation_svc, "Content Creation Service", "REST / gRPC", "Orchestrates AI-assisted content authoring, file storage and vector indexing")
    Container(content_consumption_svc, "Content Consumption Service", "REST / gRPC", "Serves, searches and recommends content; optionally enriches results via LLM")
}

' ────────────────────────────────
' EXTERNAL SERVICES
' ────────────────────────────────
System_Boundary(external, "External Services") {
    System_Ext(auth_api, "Auth API", "Third-party identity provider (e.g. OAuth 2.0 / OIDC)")
    System_Ext(llm_api, "LLM API", "Large Language Model provider (e.g. Anthropic / OpenAI)")
}

' ────────────────────────────────
' DATA STORES
' ────────────────────────────────
System_Boundary(data, "Data Layer") {
    ContainerDb(postgres, "Relational Database", "PostgreSQL", "Stores users, content metadata and transactional records")
    ContainerDb(vector_db, "Vector Store", "pgvector / Weaviate / Qdrant", "Stores and queries high-dimensional embeddings for semantic search")
    ContainerDb(object_store, "Object Store", "S3-compatible / MinIO", "Stores binary assets — images, documents and media files")
    ContainerDb(cache, "Cache", "Redis / Valkey", "Stores sessions, rate-limit counters and hot query results")
}

' ────────────────────────────────
' RELATIONSHIPS — Client → Gateway
' ────────────────────────────────
Rel(mobile_app, api_gateway, "API calls", "HTTPS")
Rel(web_app,    api_gateway, "API calls", "HTTPS")

' ────────────────────────────────
' RELATIONSHIPS — Gateway → Services
' ────────────────────────────────
Rel(api_gateway, identity_svc,           "Routes auth requests",    "HTTPS / gRPC")
Rel(api_gateway, content_creation_svc,   "Routes creation requests", "HTTPS / gRPC")
Rel(api_gateway, content_consumption_svc,"Routes consumption requests", "HTTPS / gRPC")

' ────────────────────────────────
' RELATIONSHIPS — Identity Service
' ────────────────────────────────
Rel(identity_svc, auth_api,  "Delegates external auth", "HTTPS")
Rel(identity_svc, postgres,  "Reads / writes user records", "TCP")
Rel(identity_svc, cache,     "Stores session tokens", "TCP")

' ────────────────────────────────
' RELATIONSHIPS — Content Creation Service
' ────────────────────────────────
Rel(content_creation_svc, llm_api,     "Generates content via LLM", "HTTPS")
Rel(content_creation_svc, postgres,    "Persists content metadata", "TCP")
Rel(content_creation_svc, vector_db,   "Indexes content embeddings", "TCP")
Rel(content_creation_svc, object_store,"Stores binary assets", "HTTPS / S3 API")

' ────────────────────────────────
' RELATIONSHIPS — Content Consumption Service
' ────────────────────────────────
Rel(content_consumption_svc, postgres,    "Queries content records", "TCP")
Rel(content_consumption_svc, vector_db,   "Semantic search on embeddings", "TCP", "optional")
Rel(content_consumption_svc, llm_api,     "Re-ranking / summarisation", "HTTPS", "optional")
Rel(content_consumption_svc, cache,       "Caches frequent queries", "TCP")

@enduml

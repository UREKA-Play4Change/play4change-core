  <!-- About -->
  <string name="about_title">À propos</string>
  <string name="about_project_title">Le Projet</string>
  <string name="about_project_body">U!REKA Play4Change est un jeu sérieux multiplateforme où les joueurs reçoivent des défis quotidiens générés par IA alignés sur les thèmes de durabilité et d\'éducation numérique. Développé dans le cadre de la Licenciatura em Engenharia Informática e de Computadores à l\'ISEL.</string>
  <string name="about_built_with">Développé Avec</string>
  <string name="about_architecture_title">Architecture</string>
  <string name="about_architecture_body">Architecture hexagonale avec pipeline IA Ports &amp; Adapters. La génération de contenu IA s\'exécute en traitement nocturne, éliminant la latence d\'inférence de l\'expérience utilisateur. Les branches adaptatives fournissent une remédiation personnalisée via la recherche de similarité sémantique avec pgvector.</string>
  <string name="about_author_label">Auteur</string>
  <string name="about_author_name">Radesh Ilesh Gamanbhai Govind</string>
  <string name="about_student_number">51620</string>
  <string name="about_institution">ISEL — Instituto Superior de Engenharia de Lisboa</string>
  <string name="about_supervisors">Prof. Nuno Datia · Prof. António Serrador · Prof. Michel Vorenhout</string>
  <string name="about_footer">Mars 2026 · U!REKA European University</string>


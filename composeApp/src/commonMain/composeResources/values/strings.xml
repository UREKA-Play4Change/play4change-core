  <!-- About -->
  <string name="about_title">About</string>
  <string name="about_project_title">The Project</string>
  <string name="about_project_body">U!REKA Play4Change is a multiplatform serious game where players receive AI-generated daily challenges aligned with sustainability and digital education themes. Built as part of the Licenciatura em Engenharia Informática e de Computadores at ISEL.</string>
  <string name="about_built_with">Built With</string>
  <string name="about_architecture_title">Architecture</string>
  <string name="about_architecture_body">Hexagonal architecture with a Ports &amp; Adapters AI pipeline. AI content generation runs as a nightly batch job, eliminating inference latency from the user experience. Adaptive branches provide personalised remediation via semantic similarity search using pgvector.</string>
  <string name="about_author_label">Author</string>
  <string name="about_author_name">Radesh Ilesh Gamanbhai Govind</string>
  <string name="about_student_number">51620</string>
  <string name="about_institution">ISEL — Instituto Superior de Engenharia de Lisboa</string>
  <string name="about_supervisors">Prof. Nuno Datia · Prof. António Serrador · Prof. Michel Vorenhout</string>
  <string name="about_questionnaire_title">Share Your Feedback</string>
  <string name="about_questionnaire_body">Help shape the future of Play4Change. Your experience matters — take a moment to answer our questionnaire.</string>
  <string name="about_questionnaire_cta">Open questionnaire</string>
  <string name="about_footer">March 2026 · U!REKA European University</string>


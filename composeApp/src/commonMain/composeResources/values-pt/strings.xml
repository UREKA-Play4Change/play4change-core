  <!-- About -->
  <string name="about_title">Sobre</string>
  <string name="about_project_title">O Projeto</string>
  <string name="about_project_body">U!REKA Play4Change é um jogo sério multiplataforma onde os jogadores recebem desafios diários gerados por IA alinhados com temas de sustentabilidade e educação digital. Desenvolvido como parte da Licenciatura em Engenharia Informática e de Computadores no ISEL.</string>
  <string name="about_built_with">Desenvolvido Com</string>
  <string name="about_architecture_title">Arquitetura</string>
  <string name="about_architecture_body">Arquitetura hexagonal com pipeline de IA Ports &amp; Adapters. A geração de conteúdo por IA é executada como um trabalho batch nocturno, eliminando a latência de inferência da experiência do utilizador. Os ramos adaptativos fornecem remediação personalizada via pesquisa de similaridade semântica usando pgvector.</string>
  <string name="about_author_label">Autor</string>
  <string name="about_author_name">Radesh Ilesh Gamanbhai Govind</string>
  <string name="about_student_number">51620</string>
  <string name="about_institution">ISEL — Instituto Superior de Engenharia de Lisboa</string>
  <string name="about_supervisors">Prof. Nuno Datia · Prof. António Serrador · Prof. Michel Vorenhout</string>
  <string name="about_footer">Março 2026 · U!REKA European University</string>

